<!doctype html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Padel Rangliste — Forside</title>
    <meta name="description" content="Padel Rangliste — find baner, opret kampe og følg din rangliste." />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2250%22 r=%2240%22 fill=%22%2334d399%22/></svg>">
    <style>
        :root{
            --bg:#0f172a; /* dark navy */
            --accent:#34d399; /* teal */
            --muted:#94a3b8;
            --card:#0b1220;
            --glass: rgba(255,255,255,0.04);
            --radius:14px;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
        }
        *{box-sizing:border-box}
        html,body{height:100%}
        body{
            margin:0;
            background: linear-gradient(180deg,#071028 0%, #071524 60%);
            color: #e6eef8;
            -webkit-font-smoothing:antialiased;
            -moz-osx-font-smoothing:grayscale;
            line-height:1.45;
            display:flex;
            flex-direction:column;
            min-height:100vh;
        }

        header{
            width:100%;
            padding:18px 28px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:16px;
            position:sticky;
            top:0;
            background:linear-gradient(180deg, rgba(2,6,23,0.6), rgba(2,6,23,0.25));
            backdrop-filter: blur(6px);
            z-index:10;
        }
        .brand{
            display:flex;
            gap:12px;
            align-items:center;
        }
        .logo{
            width:44px;
            height:44px;
            background:linear-gradient(135deg,var(--accent), #06b6d4);
            display:grid;
            place-items:center;
            border-radius:10px;
            box-shadow: 0 6px 18px rgba(6,95,70,0.18);
            font-weight:700;
            color:#022; 
        }
        nav{display:flex;gap:18px;align-items:center}
        nav a{
            color:var(--muted);
            text-decoration:none;
            font-weight:600;
            font-size:15px;
            padding:8px 12px;
            border-radius:10px;
        }
        nav a.primary{
            background:linear-gradient(90deg,var(--accent),#06b6d4);
            color:#022;
            box-shadow: 0 8px 30px rgba(6,95,70,0.12);
        }
        .menu-btn{
            display:none;
            background:transparent;
            border:0;
            color:var(--muted);
            font-size:20px;
        }

        main{flex:1;display:flex;align-items:stretch}
        .hero{
            width:100%;
            display:grid;
            grid-template-columns: 1fr 420px;
            gap:28px;
            align-items:center;
            padding:56px 64px;
        }
        .hero-left{
            max-width:760px;
        }
        h1{
            margin:0 0 12px 0;
            font-size:42px;
            line-height:1.02;
            letter-spacing:-0.02em;
            color: #eef8ff;
        }
        p.lead{
            margin:0 0 22px 0;
            color:var(--muted);
            font-size:18px;
            max-width:56ch;
        }

        .cta-row{display:flex;gap:12px;align-items:center}
        .btn{
            padding:12px 18px;
            border-radius:12px;
            font-weight:700;
            border:0;
            cursor:pointer;
            font-size:15px;
        }
        .btn-primary{background:linear-gradient(90deg,var(--accent),#06b6d4); color:#022;}
        .btn-ghost{background:transparent;color:var(--accent);border:1px solid rgba(255,255,255,0.06);}

        .features{
            margin-top:28px;
            display:flex;
            gap:14px;
            flex-wrap:wrap;
        }
        .feature{
            background:var(--glass);
            padding:12px 14px;
            border-radius:12px;
            display:flex;
            gap:12px;
            align-items:center;
            color:var(--muted);
            min-width:180px;
        }
        .feature svg{width:34px;height:34px;flex:0 0 34px}

        .hero-right{
            position:relative;
            display:flex;
            align-items:center;
            justify-content:center;
        }
        .card{
            width:100%;
            max-width:420px;
            background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
            border-radius:var(--radius);
            padding:20px;
            box-shadow: 0 10px 30px rgba(2,6,23,0.5);
            border:1px solid rgba(255,255,255,0.03);
        }
        .card h3{margin:0 0 8px 0;font-size:18px}
        .card p{margin:0 0 16px 0;color:var(--muted)}
        .list{
            display:flex;
            flex-direction:column;
            gap:10px;
        }
        .list .row{
            display:flex;justify-content:space-between;align-items:center;padding:10px;border-radius:10px;background:rgba(255,255,255,0.02);
        }
        .racket{
            position:absolute;
            right:30px;
            top:16%;
            transform:rotate(18deg);
            opacity:0.95;
            filter: drop-shadow(0 10px 30px rgba(6,95,70,0.08));
        }

        footer{
            padding:20px 28px;
            color:var(--muted);
            border-top:1px solid rgba(255,255,255,0.02);
            display:flex;
            justify-content:space-between;
            align-items:center;
            gap:12px;
            flex-wrap:wrap;
        }

        /* Responsive */
        @media (max-width:980px){
            .hero{grid-template-columns:1fr; padding:36px 22px}
            .hero-right{order:-1;margin-bottom:18px}
            nav{display:none}
            .menu-btn{display:inline-flex}
        }
        @media (max-width:480px){
            h1{font-size:30px}
        }
    </style>
</head>
<body>
    <header>
        <div class="brand" aria-label="Padel Rangliste">
            <div class="logo" aria-hidden="true">PR</div>
            <div>
                <div style="font-weight:800">Padel Rangliste</div>
                <div style="font-size:12px;color:var(--muted)">Find spil. Følg din udvikling.</div>
            </div>
        </div>

        <nav role="navigation" aria-label="Hovedmenu">
            <a href="#baner">Baner</a>
            <a href="#kampe">Kampe</a>
            <a href="#rangliste">Rangliste</a>
            <a class="primary" href="#tilmeld">Tilmeld</a>
        </nav>

        <button class="menu-btn" aria-label="Åbn menu" onclick="toggleMenu()">☰</button>
    </header>

    <main>
        <section class="hero" aria-labelledby="hero-title">
            <div class="hero-left">
                <h1 id="hero-title">Velkommen til Padel Rangliste</h1>
                <p class="lead">En enkel og moderne forside til din padel-klub. Find baner, opret kampe, udfordre venner og følg din rangliste over tid.</p>

                <div class="cta-row">
                    <button class="btn btn-primary" onclick="location.href='#tilmeld'">Tilmeld dig gratis</button>
                    <button class="btn btn-ghost" onclick="location.href='#rangliste'">Se rangliste</button>
                </div>

                <div class="features" aria-hidden="false">
                    <div class="feature">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v6" stroke="#34d399" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12h12" stroke="#7dd3fc" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 18h16" stroke="#93c5fd" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <div>
                            <div style="font-weight:700">Find baner</div>
                            <div style="font-size:13px;color:var(--muted)">Se åbningstider og ledige tider nær dig.</div>
                        </div>
                    </div>

                    <div class="feature">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="3" stroke="#fca5a5" stroke-width="1.6"/><path d="M20.5 12a8.5 8.5 0 1 0-17 0" stroke="#fecaca" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <div>
                            <div style="font-weight:700">Opret kampe</div>
                            <div style="font-size:13px;color:var(--muted)">Inviter modstandere, sæt tidspunkt og banetype.</div>
                        </div>
                    </div>

                    <div class="feature">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 12h18" stroke="#c7b8ff" stroke-width="1.6" stroke-linecap="round"/><path d="M6 8v8" stroke="#a78bfa" stroke-width="1.6" stroke-linecap="round"/><path d="M12 6v12" stroke="#7c3aed" stroke-width="1.6" stroke-linecap="round"/><path d="M18 10v6" stroke="#5b21b6" stroke-width="1.6" stroke-linecap="round"/></svg>
                        <div>
                            <div style="font-weight:700">Følg rangliste</div>
                            <div style="font-size:13px;color:var(--muted)">Se din placering og statistik over tid.</div>
                        </div>
                    </div>
                </div>
            </div>

            <aside class="hero-right" aria-label="Live preview kort">
                <div class="card" role="region" aria-labelledby="card-title">
                    <h3 id="card-title">Næste kampe</h3>
                    <p>Overblik over bookede kampe og inviterede spillere.</p>

                    <div class="list" aria-live="polite">
                        <div class="row">
                            <div>
                                <div style="font-weight:700">Ons 18:00 — Klub A</div>
                                <div style="font-size:13px;color:var(--muted)">2 spillere meldt — 2 pladser tilbage</div>
                            </div>
                            <div style="font-size:13px;color:var(--muted)">Bane 3</div>
                        </div>

                        <div class="row">
                            <div>
                                <div style="font-weight:700">Fre 20:30 — Venner</div>
                                <div style="font-size:13px;color:var(--muted)">Privat kamp — 4 spillere</div>
                            </div>
                            <div style="font-size:13px;color:var(--muted)">Bane 1</div>
                        </div>

                        <div class="row">
                            <div>
                                <div style="font-weight:700">Søn 10:00 — Turnering</div>
                                <div style="font-size:13px;color:var(--muted)">Åben tilmelding</div>
                            </div>
                            <div style="font-size:13px;color:var(--muted)">Bane 2</div>
                        </div>
                    </div>
                </div>

                <!-- decorative racket SVG -->
                <svg class="racket" width="220" height="220" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <defs>
                        <linearGradient id="g1" x1="0" x2="1" y1="0" y2="1">
                            <stop offset="0" stop-color="#34d399"/>
                            <stop offset="1" stop-color="#06b6d4"/>
                        </linearGradient>
                    </defs>
                    <g transform="rotate(18 32 32)">
                        <rect x="6" y="6" width="28" height="28" rx="8" fill="url(#g1)" opacity="0.95"/>
                        <rect x="30" y="30" width="28" height="6" rx="3" fill="#0b1220"/>
                        <circle cx="18" cy="18" r="6" fill="#071024" opacity="0.7"/>
                    </g>
                </svg>
            </aside>
        </section>
    </main>

    <footer>
        <div>© <strong>Padel Rangliste</strong> — Alle rettigheder forbeholdes</div>
        <div style="display:flex;gap:12px;align-items:center">
            <a href="#kontakt" style="color:var(--muted);text-decoration:none">Kontakt</a>
            <a href="#privacy" style="color:var(--muted);text-decoration:none">Privatliv</a>
        </div>
    </footer>

    <script>
        function toggleMenu(){
            // Enkel mobilmenu: skift nav synlighed
            const nav = document.querySelector('nav');
            if(!nav) return;
            nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
            nav.style.flexDirection = 'column';
            nav.style.position = 'absolute';
            nav.style.right = '20px';
            nav.style.top = '68px';
            nav.style.background = 'rgba(2,6,23,0.95)';
            nav.style.padding = '12px';
            nav.style.borderRadius = '12px';
            nav.style.boxShadow = '0 10px 30px rgba(2,6,23,0.6)';
        }

        // Demo: fokus på CTA med adgangstast (accessible shortcut)
        document.addEventListener('keydown', (e) => {
            if ((e.altKey || e.metaKey) && e.key.toLowerCase() === 't') {
                e.preventDefault();
                const btn = document.querySelector('.btn-primary');
                if (btn) btn.focus();
            }
        });
    </script>
</body>
</html>